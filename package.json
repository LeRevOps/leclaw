{
  "name": "@revtown/core",
  "version": "0.3.8",
  "description": "Open-source RevOps agent hub for HubSpot and Salesforce",
  "type": "module",
  "main": "./core/index.js",
  "types": "./core/index.d.ts",
  "bin": {
    "revtown": "cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./core/index.js",
      "types": "./core/index.d.ts"
    }
  },
  "files": [
    "core/*.ts",
    "core/*.js",
    "core/*.d.ts",
    "!core/*.test.ts",
    "!core/*.test.js",
    "!core/*.test.d.ts",
    "agents/**/*.ts",
    "agents/**/*.js",
    "agents/**/*.d.ts",
    "cli/**/*.js",
    "cli/**/*.d.ts",
    "examples/",
    "setup.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "node cli/index.js",
    "setup": "node setup.js",
    "data-quality": "node agents/le-data-quality/index.js",
    "registry": "node scripts/build-registry.js",
    "docker:build": "npm run build && docker build -t leclaw/runner:0.3.6 -t leclaw/runner:latest .",
    "docker:push": "docker push leclaw/runner:0.3.6 && docker push leclaw/runner:latest"
  },
  "keywords": [
    "revops",
    "salesops",
    "hubspot",
    "salesforce",
    "agents",
    "crm",
    "gtm",
    "automation"
  ],
  "author": "Revtown <hello@revtown.io>",
  "license": "MIT",
  "homepage": "https://revtown.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeRevOps/revtown.git"
  },
  "bugs": {
    "url": "https://github.com/LeRevOps/revtown/issues"
  },
  "dependencies": {
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
