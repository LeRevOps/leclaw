# ── HubSpot ──────────────────────────────────────────────
# Create a private app at app.hubspot.com → Settings → Integrations → Private Apps
HUBSPOT_API_TOKEN=your_hubspot_private_app_token

# ── Salesforce ───────────────────────────────────────────
# OAuth2 access token from your connected app
SALESFORCE_ACCESS_TOKEN=your_salesforce_access_token
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com

# ── AI ───────────────────────────────────────────────────
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Slack ────────────────────────────────────────────────
# Create incoming webhook at api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
